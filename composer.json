{
    "name": "devsimsek/project-sdf",
    "description": "SDF Framework",
    "type": "project",
    "require": {
        "php": ">=8.0",
        "ext-pdo": "*",
        "psr/http-message": "^2.0"
    },
    "require-dev": {
        "zircote/swagger-php": "^4.0",
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "autoload": {
        "psr-4": {
            "SDF\\": "sdf/core/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit --testdox",
        "cs:fix": "vendor/bin/php-cs-fixer fix --config .php-cs-fixer.dist.php",
        "cs:check": "vendor/bin/php-cs-fixer fix --config .php-cs-fixer.dist.php --dry-run --diff",
        "analyze": "vendor/bin/phpstan analyse -c phpstan.neon"
    },
    "suggest": {
        "ext-zlib": "Required only for gzipped log rotation.",
        "ext-pcntl": "Required only for async logging fork mode."
    },
    "authors": [
        {
            "name": "devsimsek",
            "email": "75851971+devsimsek@users.noreply.github.com"
        }
    ]
}
