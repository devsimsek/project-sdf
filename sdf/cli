#!/usr/bin/env php
<?php namespace SDF;

require_once __DIR__ . "/core/Spark.php";

use PDO;

/**
 * Class CLI
 * The SDF command-line interface. Handles code generation, database operations, and dev server.
 */
class CLI
{
    /** @var array $argv Command-line arguments. */
    private array $argv;

    /** @var array $config Key-value env/config store. */
    private array $config = [];

    /**
     * @param array $argv
     */
    public function __construct(array $argv)
    {
        $this->argv = $argv;
        $this->loadEnvironment();
    }

    /**
     * Load framework environment and configurations.
     */
    private function loadEnvironment(): void
    {
        define("SDF_ROOT", dirname(__DIR__));
        define("SDF_APP", SDF_ROOT . "/app/");
        define("SDF_DIR", SDF_ROOT . "/sdf/");

        // Load .env and helpers before config so env() is available
        require_once SDF_DIR . "core/Env.php";
        require_once SDF_DIR . "core/helpers.php";
        \SDF\Env::load(SDF_ROOT . '/.env');

        require_once SDF_DIR . "core/Core.php";
        Core::coreLoadConfigurations();

        // Load Cache facade so clearCache() can flush it
        if (!class_exists(\SDF\Cache\Cache::class, false)) {
            require_once SDF_DIR . "core/Cache/__init.php";
        }

        $this->config = Core::coreGetConfig("database") ?: [];
    }

    /**
     * Main dispatcher.
     */
    public function handle(): void
    {
        if (count($this->argv) < 2) {
            $this->printUsage();
            exit(1);
        }

        $command = $this->argv[1];

        switch ($command) {
            case "g":
            case "generate":
                $this->handleGenerate();
                break;
            case "db":
            case "database":
                $this->handleDatabase();
                break;
            case "serve":
            case "devserver":
                $this->handleDevServer();
                break;
            case "test":
            case "tests":
                $this->handleTests();
                break;
            case "cache":
                $this->handleCache();
                break;
            case "format":
            case "fmt":
                $this->handleFormatter();
                break;
            case "benchmark":
            case "bench":
                $this->handleBenchmark();
                break;
            case "swagger":
                $this->handleSwagger();
                break;
            default:
                $this->printUsage();
                break;
        }
    }

    // ─── Generators ──────────────────────────────────────────────────────────

    /**
     * Route to sub-generator based on argv[2].
     */
    private function handleGenerate(): void
    {
        if (count($this->argv) < 3) {
            $this->printUsage();
            exit(1);
        }

        $subCommand = $this->argv[2];
        $name = $this->argv[3] ?? null;

        switch ($subCommand) {
            case "model":
            case "m":
                $this->generateModel($name);
                break;
            case "migration":
            case "migrate":
                $this->generateMigration($name);
                break;
            case "controller":
            case "c":
                $this->generateController($name);
                break;
            case "route":
            case "r":
                $this->generateRoute($name);
                break;
            case "helper":
            case "h":
                $this->generateHelper($name);
                break;
            case "config":
            case "cfg":
                $this->generateConfig($name);
                break;
            case "view":
            case "v":
                $this->generateView($name);
                break;
            case "seeder":
            case "s":
                $this->generateSeeder($name);
                break;
            case "middleware":
            case "mw":
                $this->generateMiddleware($name);
                break;
            case "guard":
            case "g":
                $this->generateGuard($name);
                break;
            case "test":
            case "t":
                $this->generateTest($name);
                break;
            default:
                $this->printUsage();
                break;
        }
    }

    /**
     * Generate a Spark ORM model file.
     *
     * @param string|null $name
     */
    private function generateModel(?string $name): void
    {
        if (!$name) {
            echo "Model name can't be empty.\n";
            $name = readline("Enter model name: ");
        }

        @mkdir("app/models", 0755, true);
        $file = "app/models/$name.php";
        $template = <<<'PHP'
        <?php

        use SDF\Spark\Model;

        /**
         * Model __NAME__
         */
        class __NAME__ extends Model
        {
            // Override table name if needed:
            // protected static string $table = '__NAME__s';
        }
        PHP;
        file_put_contents($file, strtr($template, ["__NAME__" => $name]));
        echo "Model '$name' created at $file\n";
    }

    /**
     * Generate a migration stub using Spark ORM.
     *
     * @param string|null $name
     */
    private function generateMigration(?string $name): void
    {
        if (!$name) {
            echo "Migration name can't be empty.\n";
            $name = readline("Enter migration name: ");
        }

        @mkdir("app/migrations", 0755, true);
        $timestamp = date("YmdHis");
        $className = "{$name}_{$timestamp}";
        $file = "app/migrations/{$className}.php";

        $template = <<<'PHP'
        <?php

        /**
         * Migration: __NAME__
         * Created: __TIMESTAMP__
         */
        use SDF\Spark\Migration;

        class __CLASS__ extends Migration
        {
            /**
             * Run the migrations.
             *
             * @param \PDO $pdo
             * @return void
             */
            public function up(\PDO $pdo): void
            {
                // Example:
                // $pdo->exec("CREATE TABLE users (id INT AUTO_INCREMENT PRIMARY KEY, name VARCHAR(255))");
            }

            /**
             * Reverse the migrations.
             *
             * @param \PDO $pdo
             * @return void
             */
            public function down(\PDO $pdo): void
            {
                // Example:
                // $pdo->exec("DROP TABLE users");
            }
        }
        PHP;
        file_put_contents(
            $file,
            strtr($template, [
                "__NAME__" => $name,
                "__CLASS__" => $className,
                "__TIMESTAMP__" => $timestamp,
            ]),
        );
        echo "Migration '$className' created at $file\n";
    }

    /**
     * Generate a controller file.
     *
     * @param string|null $name
     */
    private function generateController(?string $name): void
    {
        if (!$name) {
            echo "Controller name can't be empty.\n";
            $name = readline("Enter controller name: ");
        }

        @mkdir(dirname("app/controllers/$name.php"), 0755, true);
        $file = "app/controllers/$name.php";
        $template = <<<'PHP'
        <?php

        use SDF\Controller;

        /**
         * Controller __NAME__
         */
        class __NAME__ extends Controller
        {
            /**
             * Default action.
             */
            public function index(): void
            {
                // Example of rendering a view:
                // $this->view('__NAME__/index', ['title' => 'Welcome']);

                echo "Welcome to __NAME__ Controller";
            }
        }
        PHP;
        file_put_contents($file, strtr($template, ["__NAME__" => $name]));
        echo "Controller '$name' created at $file\n";
    }

    /**
     * Append a new route to routes config.
     *
     * @param string|null $name
     */
    private function generateRoute(?string $name): void
    {
        if (!$name) {
            echo "Route name can't be empty.\n";
            $name = readline("Enter route name: ");
        }

        $controllerMethod = $this->argv[4] ?? "Controller/method";
        $requestType = $this->argv[5] ?? "GET";

        file_put_contents(
            "app/config/routes.php",
            "\n\$config['/$name'] = ['$controllerMethod', '$requestType'];",
            FILE_APPEND,
        );
        echo "Route '/$name' appended to app/config/routes.php\n";
    }

    /**
     * Generate a helper file.
     *
     * @param string|null $name
     */
    private function generateHelper(?string $name): void
    {
        if (!$name) {
            echo "Helper name can't be empty.\n";
            $name = readline("Enter helper name: ");
        }

        @mkdir("app/helpers", 0755, true);
        $file = "app/helpers/$name.php";
        file_put_contents($file, "<?php\n\n// Helper: $name\n");
        echo "Helper '$name' created at $file\n";
    }

    /**
     * Generate a config file.
     *
     * @param string|null $name
     */
    private function generateConfig(?string $name): void
    {
        if (!$name) {
            echo "Config name can't be empty.\n";
            exit(1);
        }

        @mkdir("app/config", 0755, true);
        $file = "app/config/$name.php";
        $template = <<<'PHP'
        <?php

        /**
         * __NAME__ Configuration
         * Load using: loadConfig('__NAME__');
         * @var array $config
         */
        if (!defined('SDF')) die('Security warning.');

        $config['__NAME__'] = [
            'key' => 'value',
        ];
        PHP;
        file_put_contents($file, strtr($template, ["__NAME__" => $name]));
        echo "Config '$name' created at $file\n";
    }

    /**
     * Generate a view file.
     *
     * @param string|null $name
     */
    private function generateView(?string $name): void
    {
        if (!$name) {
            echo "View name can't be empty.\n";
            exit(1);
        }

        @mkdir(dirname("app/views/$name.php"), 0755, true);
        $file = "app/views/$name.php";
        file_put_contents($file, "<h1>$name works!</h1>\n");
        echo "View '$name' created at $file\n";
    }

    /**
     * Generate a seeder file.
     *
     * @param string|null $name
     */
    private function generateSeeder(?string $name): void
    {
        if (!$name) {
            echo "Seeder name can't be empty.\n";
            exit(1);
        }

        @mkdir("app/seeds", 0755, true);
        $file = "app/seeds/$name.php";
        $template = <<<'PHP'
        <?php

        /**
         * Seeder: __NAME__
         */
        use SDF\Spark\Seeder;

        class __NAME__ extends Seeder
        {
            /**
             * Run the database seeds.
             *
             * @param \PDO $pdo
             * @return void
             */
            public function run(\PDO $pdo): void
            {
                // You can use raw PDO:
                // $pdo->exec("INSERT INTO users (name) VALUES ('Admin')");

                // Or use Spark ORM if you have a model:
                // \User::create(['name' => 'Admin']);
            }
