    /**
     * Generate a PHPUnit test scaffold.
     *
     * @param string|null $name
     */
    private function generateTest(?string $name): void
    {
        // Parse options: --type, --namespace, --force
        $type = null;
        $ns = null;
        $force = false;

        foreach ($this->argv as $arg) {
            if (str_starts_with($arg, "--type=")) {
                $type = strtolower(substr($arg, 7));
            }
            if (str_starts_with($arg, "--namespace=")) {
                $ns = substr($arg, 12);
            }
            if ($arg === "--force" || $arg === "-f") {
                $force = true;
            }
        }

        // support --type value (two-arg form) and --namespace two-arg form
        if ($type === null) {
            $idx = array_search("--type", $this->argv);
            if ($idx !== false && isset($this->argv[$idx + 1])) {
                $type = strtolower($this->argv[$idx + 1]);
            }
        }
        if ($ns === null) {
            $idx = array_search("--namespace", $this->argv);
            if ($idx !== false && isset($this->argv[$idx + 1])) {
                $ns = $this->argv[$idx + 1];
            }
        }

        if (!$name) {
            echo "Test name can't be empty.\n";
            $name = readline(
                "Enter test name (eg. UserControllerTest or UserTest): ",
            );
        }

        // If a positional type provided as argv[4], accept it (generate test : php sdf/cli g test Name controller)
        if ($type === null && isset($this->argv[4])) {
            $maybe = strtolower($this->argv[4]);
            // ignore flags
            if (!str_starts_with($maybe, "-")) {
                $type = $maybe;
            }
        }

        // Default type
        if ($type === null || $type === "") {
            $type = "unit";
        }

        // Normalize name and path
        if (str_ends_with($name, "Test")) {
            $className = $name;
        } else {
            $className = $name . "Test";
        }

        $path = "tests/" . str_replace("\\", "/", $className) . ".php";
        $dir = dirname($path);
        @mkdir($dir, 0755, true);

        if (file_exists($path) && !$force) {
            echo "Test file already exists: $path (use --force to overwrite)\n";
            return;
        }

        $shortClass = basename($className);
        // Determine target class FQCN and instantiation name
        $defaultTarget = preg_replace('/Test$/', "", $shortClass);
        if (!empty($ns)) {
            // If namespace provided, accept either 'App\\Controllers\\User' or 'App/Controllers/User'
            $fqn = str_replace("/", "\\", trim($ns, "\\/"));
            $targetClass = $fqn; // used for 'use' imports
            $instName = preg_replace("/^.*\\\\/", "", $fqn); // short class name for instantiation
        } else {
            $targetClass = $defaultTarget;
            $instName = $defaultTarget;
        }

        // Templates per type
        $content = match ($type) {
            "controller" => strtr(
                <<<'PHP'
                <?php

                namespace Tests;

                use PHPUnit\Framework\TestCase;
                use SDF\Request;
                use SDF\Response;
                __TARGET_USE__

                class __SHORT_CLASS__ extends TestCase
                {
                    protected Request|\PHPUnit\Framework\MockObject\MockObject $requestMock;
                    protected Response|\PHPUnit\Framework\MockObject\MockObject $responseMock;

                    protected function setUp(): void
                    {
                        parent::setUp();
                        $this->requestMock = $this->createMock(Request::class);
                        $this->responseMock = $this->createMock(Response::class);
                    }

                    public function test_index_action_exists(): void
                    {
                        $controller = new __INST_NAME__();
                        $this->assertTrue(method_exists($controller, 'index') || method_exists($controller, 'handle'));
                    }
                }
                PHP
                ,
                [
                    "__SHORT_CLASS__" => $shortClass,
                    "__INST_NAME__" => $instName,
                    "__TARGET_USE__" => !empty($ns)
                        ? "use " . $targetClass . ";"
                        : '// Replace with your controller\'s FQCN if namespaced',
                ],
            ),
            "model" => strtr(
                <<<'PHP'
                <?php

                namespace Tests;

                use PHPUnit\Framework\TestCase;
                use __TARGET__;

                class __SHORT_CLASS__ extends TestCase
                {
                    public function test_model_dirty_and_fill(): void
                    {
                        $model = new __TARGET__([]);
                        $model->fill(['name' => 'Alice']);
                        $this->assertTrue($model->isDirty());
                        $dirty = $model->getDirty();
                        $this->assertArrayHasKey('name', $dirty);
                    }
                }
                PHP
                ,
                [
                    "__SHORT_CLASS__" => $shortClass,
                    "__TARGET__" => $targetClass,
                ],
            ),
            "integration" => <<<PHP
            <?php

            namespace Tests;

            use PHPUnit\Framework\TestCase;
            use SDF\Spark;

            class $shortClass extends TestCase
            {
                public function test_sqlite_in_memory_example(): void
                {
                    Spark::connect('sqlite::memory:');
                    \$pdo = Spark::pdo();

                    \$pdo->exec("CREATE TABLE items (id INTEGER PRIMARY KEY AUTOINCREMENT, name TEXT);");
                    \$stmt = \$pdo->prepare("INSERT INTO items (name) VALUES (?)");
                    \$stmt->execute(['alpha']);

                    \$count = \$pdo->query('SELECT COUNT(*) FROM items')->fetchColumn();
                    \$this->assertSame(1, (int)\$count);
                }
            }
            PHP,
            default => <<<'PHP'
            <?php

            namespace Tests;

            use PHPUnit\Framework\TestCase;
            use SDF\Request;
            use SDF\Response;

            class __SHORT_CLASS__ extends TestCase
            {
                protected Request|\PHPUnit\Framework\MockObject\MockObject $requestMock;
                protected Response|\PHPUnit\Framework\MockObject\MockObject $responseMock;

                protected function setUp(): void
                {
                    parent::setUp();
                    $this->requestMock = $this->createMock(Request::class);
                    $this->responseMock = $this->createMock(Response::class);
                }

                public function test_example_with_mock(): void
                {
                    $this->requestMock->method('get')->with('id')->willReturn(123);
                    $this->assertSame(123, $this->requestMock->get('id'));
                }
            }
            PHP,
        };

        $content = strtr($content, [
            "__SHORT_CLASS__" => $shortClass,
        ]);

        file_put_contents($path, $content);
        echo "Test '{$shortClass}' (type: {$type}) created at $path\n";
    }

    // ─── Database ─────────────────────────────────────────────────────────────

    /**
     * Route to database sub-commands.
     */
    private function handleDatabase(): void
    {
        if (count($this->argv) < 3) {
            $this->printUsage();
            exit(1);
        }

        switch ($this->argv[2]) {
            case "migrate":
                $this->migrate();
                break;
            case "rollback":
                $this->rollback();
                break;
            case "seed":
                $this->seed();
                break;
            case "reset":
                $this->reset();
                break;
            default:
                $this->printUsage();
                break;
        }
    }

    /**
     * Run all pending migrations.
     */
    private function migrate(): void
    {
        $pdo = $this->getPdo();
        $this->ensureMigrationTable($pdo);

        $stmt = $pdo->query("SELECT migration FROM migrations");
        $ran = $stmt->fetchAll(PDO::FETCH_COLUMN);

        $files = glob("app/migrations/*.php");
        $batch =
            (int) $pdo
                ->query("SELECT MAX(batch) FROM migrations")
                ->fetchColumn() + 1;

        $count = 0;
        echo "Running migrations...\n";

        foreach ($files as $file) {
            $name = pathinfo($file, PATHINFO_FILENAME);
            if (in_array($name, $ran)) {
                continue;
            }

            echo "  → $name\n";
            require_once $file;
            $migration = new $name();
            $migration->up($pdo);

            $stmt = $pdo->prepare(
                "INSERT INTO migrations (migration, batch) VALUES (?, ?)",
            );
            $stmt->execute([$name, $batch]);
            $count++;
        }

        if ($count === 0) {
            echo "Nothing to migrate.\n";
        } else {
            echo "$count migration(s) completed.\n";
        }
    }

    /**
     * Ensure migrations table exists.
     */
    private function ensureMigrationTable(PDO $pdo): void
    {
        $driver = $pdo->getAttribute(PDO::ATTR_DRIVER_NAME);

        switch ($driver) {
            case "sqlite":
                $sql = "
          CREATE TABLE IF NOT EXISTS migrations (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            migration TEXT NOT NULL,
            batch INTEGER NOT NULL,
            created_at TEXT DEFAULT CURRENT_TIMESTAMP
          )
        ";
                break;
            case "pgsql":
                $sql = "
          CREATE TABLE IF NOT EXISTS migrations (
            id BIGSERIAL PRIMARY KEY,
            migration VARCHAR(255) NOT NULL,
            batch INTEGER NOT NULL,
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
          )
        ";
                break;
            case "sqlsrv":
                $sql = "
          IF OBJECT_ID('migrations', 'U') IS NULL
          BEGIN
            CREATE TABLE migrations (
              id INT IDENTITY(1,1) PRIMARY KEY,
              migration VARCHAR(255) NOT NULL,
              batch INT NOT NULL,
              created_at DATETIME2 DEFAULT CURRENT_TIMESTAMP
            )
          END
        ";
                break;
            case "mysql":
            default:
                $sql = "
          CREATE TABLE IF NOT EXISTS migrations (
            id INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
            migration VARCHAR(255) NOT NULL,
            batch INT NOT NULL,
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
          )
        ";
                break;
        }

        $pdo->exec($sql);
    }

    /**
     * Rollback the last migration batch.
     */
    private function rollback(): void
    {
        $pdo = $this->getPdo();
        $this->ensureMigrationTable($pdo);

        $batch = $pdo
            ->query("SELECT MAX(batch) FROM migrations")
            ->fetchColumn();
        if (!$batch) {
            echo "Nothing to rollback.\n";
            return;
        }

        $stmt = $pdo->prepare(
            "SELECT migration FROM migrations WHERE batch = ? ORDER BY id DESC",
        );
        $stmt->execute([$batch]);
        $toRollback = $stmt->fetchAll(PDO::FETCH_COLUMN);

        echo "Rolling back batch $batch...\n";

        foreach ($toRollback as $name) {
            $file = "app/migrations/$name.php";
            if (!file_exists($file)) {
                echo "  [WARNING] Migration file '$name.php' not found. Skipping SQL rollback but removing from table.\n";
            } else {
                echo "  ← $name\n";
                require_once $file;
                $migration = new $name();
                $migration->down($pdo);
            }

            $stmt = $pdo->prepare("DELETE FROM migrations WHERE migration = ?");
            $stmt->execute([$name]);
        }

        echo "Rollback complete.\n";
    }

    /**
     * Rollback all migrations and re-run them.
     */
    private function reset(): void
    {
        $pdo = $this->getPdo();
        $this->ensureMigrationTable($pdo);

        $batches = $pdo
            ->query("SELECT DISTINCT batch FROM migrations ORDER BY batch DESC")
            ->fetchAll(PDO::FETCH_COLUMN);

        if (empty($batches)) {
            echo "No migrations found to rollback.\n";
        } else {
            foreach ($batches as $batch) {
                $this->rollbackBatch($pdo, $batch);
            }
        }

        $this->migrate();
        $this->seed();
    }

    /**
     * Rollback a specific batch.
     */
    private function rollbackBatch(PDO $pdo, int $batch): void
    {
        $stmt = $pdo->prepare(
            "SELECT migration FROM migrations WHERE batch = ? ORDER BY id DESC",
        );
        $stmt->execute([$batch]);
        $toRollback = $stmt->fetchAll(PDO::FETCH_COLUMN);

        echo "Rolling back batch $batch...\n";

        foreach ($toRollback as $name) {
            $file = "app/migrations/$name.php";
            if (file_exists($file)) {
                echo "  ← $name\n";
                require_once $file;
                $migration = new $name();
                $migration->down($pdo);
            }
            $stmt = $pdo->prepare("DELETE FROM migrations WHERE migration = ?");
            $stmt->execute([$name]);
        }
    }

    /**
     * Run all seeders in app/seeds/.
     */
    private function seed(): void
    {
        $pdo = $this->getPdo();
        $files = glob("app/seeds/*.php");

        if (empty($files)) {
            echo "No seeders found in app/seeds/.\n";
            return;
        }

        echo "Seeding database...\n";
        foreach ($files as $file) {
            $name = pathinfo($file, PATHINFO_FILENAME);
            echo "  → $name\n";
            require_once $file;
            $seeder = new $name();
            $seeder->run($pdo);
        }
        echo "Seeding complete.\n";
    }

    /**
     * Build a PDO instance from framework config.
     *
     * @return PDO
     */
    private function getPdo(): PDO
    {
        $host = $this->config["host"] ?? "127.0.0.1";
        $name = $this->config["name"] ?? "";
        $user = $this->config["user"] ?? "root";
        $pass = $this->config["pass"] ?? ($this->config["password"] ?? "");
        $driver = $this->config["driver"] ?? "mysql";
        $port = $this->config["port"] ?? null;
        $path = $this->config["path"] ?? null;
        $dsn = null;

        switch ($driver) {
            case "sqlite":
                $dsn = "sqlite:" . ($path ?: $name);
                $user = null;
                $pass = null;
                break;
            case "pgsql":
            case "postgres":
            case "psql":
                if (empty($name)) {
                    die(
                        "[ERROR] Database name not configured. Check app/config/database.php\n"
                    );
                }
                $dsn =
                    "pgsql:host=" .
                    $host .
                    ";dbname=" .
                    $name .
                    ";port=" .
                    ($port ?? "5432");
                break;
            case "sqlsrv":
                if (empty($name)) {
                    die(
                        "[ERROR] Database name not configured. Check app/config/database.php\n"
                    );
                }
                $dsn =
                    "sqlsrv:Server=" .
                    $host .
                    "," .
                    ($port ?? "1433") .
                    ";database=" .
                    $name;
                break;
            case "mysql":
            default:
                if (empty($name)) {
                    die(
                        "[ERROR] Database name not configured. Check app/config/database.php\n"
                    );
                }
                $dsn =
                    "mysql:host=" .
                    $host .
                    ";dbname=" .
                    $name .
                    ";charset=utf8";
                break;
        }

        return new PDO($dsn, $user, $pass, [
            PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION,
        ]);
    }

    // ─── Formatter ────────────────────────────────────────────────────────────

    /**
     * run php-cs-fixer
     */
    private function handleFormatter(): void
    {
        // check if php-cs-fixer is installed
        $paths = [
            "vendor/bin/php-cs-fixer",
            "vendor/friendsofphp/php-cs-fixer/php-cs-fixer",
        ];
        $bin = null;
        foreach ($paths as $p) {
            if (file_exists($p)) {
                $bin = $p;
                break;
            }
        }

        if (!$bin) {
            echo "PHP-CS-Fixer not found. Please install it via Composer:\n";
            echo "composer require --dev friendsofphp/php-cs-fixer\n";
            exit(1);
        }

        $args = array_slice($this->argv, 2);
        $argString = !empty($args)
            ? " " . implode(" ", array_map("escapeshellarg", $args))
            : "";
        passthru("$bin fix $argString", $exit);
        exit($exit);
    }

    // ─── Benchmark ────────────────────────────────────────────────────────────

    /**
     * Route to benchmark sub-commands.
     */
    private function handleBenchmark(): void
    {
        if (count($this->argv) < 3) {
            $this->printUsage();
            exit(1);
        }

        switch ($this->argv[2]) {
            case "dry":
                $this->runBenchmarkDry();
                break;
            default:
                $this->runBenchmark();
                break;
        }
    }

    /**
     * Run wrk benchmark and save results to benchmark_results.txt.
     */
    private function runBenchmark(): void
    {
        // Run wrk against the dev server and print results with 30s duration and 10 concurrent connections
        // save results to a file named benchmark_results.txt in the current directory
        $port = self::getPortArg();
        $duration = 30;
        $concurrency = 10;

        echo "Running benchmark against http://localhost:$port/ for $duration seconds with $concurrency concurrent connections...\n";
        $cmd = "wrk -t{$concurrency} -c{$concurrency} -d{$duration}s http://localhost:$port/ > benchmark_results.txt";
        passthru($cmd, $exit);
        if ($exit === 0) {
            echo "Benchmark completed. Results saved to benchmark_results.txt\n";
        } else {
            echo "Benchmark failed. Please ensure wrk is installed and in your PATH.\n";
        }
        exit($exit);
    }

    /**
     * Run wrk benchmark and print results to stdout (no file output).
     */
    private function runBenchmarkDry(): void
    {
        $port = self::getPortArg();
        $duration = 30;
        $concurrency = 10;

        echo "Running dry benchmark against http://localhost:$port/ for $duration seconds with $concurrency concurrent connections...\n";
        $cmd = "wrk -t{$concurrency} -c{$concurrency} -d{$duration}s http://localhost:$port/";
        passthru($cmd, $exit);
        if ($exit !== 0) {
            echo "Benchmark failed. Please ensure wrk is installed and in your PATH.\n";
        }
        exit($exit);
    }

    // ─── Swagger ───────────────────────────────────────────────────────────────

    /**
     * Handle swagger:generate command.
     *
     * Generates and writes openapi.json to the current directory
     * or a specified output path.
     */
    private function handleSwagger(): void
    {
        if (count($this->argv) < 3) {
            $this->printUsage();
            exit(1);
        }

        if ($this->argv[2] !== "generate") {
            echo "Usage: php sdf/cli swagger generate [output-path]\n";
            exit(1);
        }

        $outputPath = $this->argv[3] ?? getcwd() . '/openapi.json';

        $generator = new \SDF\Swagger\SwaggerGenerator(
            title: 'SDF API',
            apiVersion: SDF_VERSION,
        );

        $json = $generator->generate();
        file_put_contents($outputPath, $json);

        echo "OpenAPI spec written to: $outputPath\n";
        exit(0);
    }

    // ─── Dev Server ───────────────────────────────────────────────────────────

    /**
     * Start PHP built-in dev server.
     */
    private function handleDevServer(): void
    {
        $port = self::getPortArg();
        $quiet = in_array("-q", $this->argv);
        $live = in_array("--live", $this->argv);

        if (!$quiet) {
            $this->showBanner();
            echo "[INFO] Starting SDF development server on port $port...\n";
            if ($live) {
                echo "[INFO] Live mode enabled. Watching for changes...\n";
                putenv("SDF_LIVE_RELOAD=true");
            }
        }

        if ($this->isPortInUse($port)) {
            echo "[ERROR] Port $port already in use.\n";
            exit(1);
        }

        if ($live) {
            $this->startWatcher();
        }

        $frankenphpBin = trim(shell_exec("which frankenphp 2>/dev/null") ?? "");

        if ($frankenphpBin !== "") {
            passthru("frankenphp php-server --listen :$port");
        } else {
            passthru("php -S localhost:$port index.php");
        }

        if (!$quiet) {
            echo "[INFO] Development server stopped.\n";
        }
    }

    /**
     * Run the test suite via PHPUnit.
     */
    private function handleTests(): void
    {
        // Collect any extra args after the 'test' command
        $args = array_slice($this->argv, 2);
        $argString = "";
        if (!empty($args)) {
            $argString = " " . implode(" ", array_map("escapeshellarg", $args));
        }

        // Common vendor locations for phpunit
        $phpunitPaths = [
            "vendor/bin/phpunit",
            "vendor/phpunit/phpunit/phpunit",
        ];

        $bin = null;
        foreach ($phpunitPaths as $p) {
            if (file_exists($p)) {
                $bin = $p;
                break;
            }
        }
        if (!$bin) {
            $bin = "phpunit";
        }

        // Execute phpunit and passthru the output
        passthru($bin . $argString, $exit);
        exit($exit);
    }

    /**
     * Spawn a background process to watch files and clear cache.
     */
    private static function getPortArg(): int
    {
        $argv = $GLOBALS['argv'] ?? [];
        $pIndex = array_search("-p", $argv);
        if ($pIndex !== false && isset($argv[$pIndex + 1])) {
            return (int) $argv[$pIndex + 1];
        }
        return 8080;
    }

    private function startWatcher(): void
    {
        $lockFile = sys_get_temp_dir() . "/sdf_watcher.lock";
        if (file_exists($lockFile)) {
            $pid = (int) file_get_contents($lockFile);
            if ($pid > 0) {
                $running = false;
                if (PHP_OS_FAMILY === 'Linux') {
                    $running = file_exists("/proc/$pid");
                } elseif (function_exists("posix_kill")) {
                    $running = @posix_kill($pid, 0);
                }
                if ($running) {
                    return;
                }
            }
        }

        $cmd =
            "php " . $this->argv[0] . " cache watch > /dev/null 2>&1 & echo $!";
        $pid = exec($cmd);
        file_put_contents($lockFile, $pid);
    }

    /**
     * Handle cache management commands.
     */
    private function handleCache(): void
    {
        $subCommand = $this->argv[2] ?? null;

        switch ($subCommand) {
            case "clear":
            case "flush":
                $this->clearCache();
                break;
            case "watch":
                $this->watchAndClear();
                break;
            default:
                echo "Usage: php sdf/cli cache [clear|watch]\n";
                break;
        }
    }

    /**
     * Clear all framework caches.
     */
    private function clearCache(bool $silent = false): void
    {
        $temp = sys_get_temp_dir();
        $files = [$temp . "/sdf_routes.cache", $temp . "/sdf_config.cache"];

        $count = 0;
        foreach ($files as $file) {
            if (file_exists($file)) {
                unlink($file);
                $count++;
            }
        }

        // Clear fuse cache (legacy raw files)
        $fuseCache = $temp . "/fuse_cache";
        if (is_dir($fuseCache)) {
            foreach (glob("$fuseCache/*") as $f) {
                if (is_file($f)) {
                    unlink($f);
                }
            }
            $count++;
        }

        // Flush the Cache facade (FileDriver, Redis, Memcached)
        if (class_exists(\SDF\Cache\Cache::class)) {
            try {
                \SDF\Cache\Cache::flush();
                $count++;
            } catch (\Throwable) {
                // Cache facade may fail if config is incomplete; ignore
            }
        }

        // Clear OPcache so changed PHP files (routes.php, etc.) are re-read
        if (function_exists('opcache_reset')) {
            opcache_reset();
            $count++;
        }

        if (!$silent) {
            echo "[SUCCESS] Cache cleared ($count items removed).\n";
        }
    }

    /**
     * Internal loop to watch files and clear cache.
     */
    private function watchAndClear(): void
    {
        $shouldRun = true;
        $lastHash = $this->getProjectHash();
        $reloadSignal = sys_get_temp_dir() . "/sdf_reload.signal";

        pcntl_signal(SIGTERM, function () use (&$shouldRun) {
            $shouldRun = false;
        });

        while ($shouldRun) {
            sleep(1);
            $currentHash = $this->getProjectHash();
            if ($currentHash !== $lastHash) {
                $this->clearCache(true);
                file_put_contents($reloadSignal, time());
                $lastHash = $currentHash;
            }
        }
    }

    /**
     * Get a hash of all source file mtimes.
     */
    private function getProjectHash(): string
    {
        $dirs = ["app", "sdf"];
        $mtimes = "";
        foreach ($dirs as $dir) {
            if (!is_dir($dir)) {
                continue;
            }
            $it = new \RecursiveIteratorIterator(
                new \RecursiveDirectoryIterator($dir),
            );
            foreach ($it as $file) {
                if ($file->isFile()) {
                    $mtimes .= $file->getMTime();
                }
            }
        }
        return md5($mtimes);
    }

