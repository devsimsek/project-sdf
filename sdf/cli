#!/usr/bin/env php
<?php

namespace SDF;

require_once __DIR__ . '/core/Spark.php';

use PDO;
use SDF\Spark;

/**
 * Class CLI
 * The SDF command-line interface. Handles code generation, database operations, and dev server.
 */
class CLI
{
  /** @var array $argv Command-line arguments. */
  private array $argv;

  /** @var array $config Key-value env/config store. */
  private array $config = [];

  /**
   * @param array $argv
   */
  public function __construct(array $argv)
  {
    $this->argv = $argv;
  }

  /**
   * Main dispatcher.
   */
  public function handle(): void
  {
    if (count($this->argv) < 2) {
      $this->printUsage();
      exit(1);
    }

    $command = $this->argv[1];

    switch ($command) {
      case "g":
      case "generate":
        $this->handleGenerate();
        break;
      case "db":
      case "database":
        $this->handleDatabase();
        break;
      case "serve":
      case "devserver":
        $this->handleDevServer();
        break;
      default:
        $this->printUsage();
        break;
    }
  }

  // ─── Generators ──────────────────────────────────────────────────────────

  /**
   * Route to sub-generator based on argv[2].
   */
  private function handleGenerate(): void
  {
    if (count($this->argv) < 3) {
      $this->printUsage();
      exit(1);
    }

    $subCommand = $this->argv[2];
    $name = $this->argv[3] ?? null;

    switch ($subCommand) {
      case "model":
      case "m":
        $this->generateModel($name);
        break;
      case "migration":
      case "migrate":
        $this->generateMigration($name);
        break;
      case "controller":
      case "c":
        $this->generateController($name);
        break;
      case "route":
      case "r":
        $this->generateRoute($name);
        break;
      case "helper":
      case "h":
        $this->generateHelper($name);
        break;
      case "config":
      case "cfg":
        $this->generateConfig($name);
        break;
      case "view":
      case "v":
        $this->generateView($name);
        break;
      default:
        $this->printUsage();
        break;
    }
  }

  /**
   * Generate a Spark ORM model file.
   *
   * @param string|null $name
   */
  private function generateModel(?string $name): void
  {
    if (!$name) {
      echo "Model name can't be empty.\n";
      $name = readline("Enter model name: ");
    }

    @mkdir("app/models", 0755, true);
    $file = "app/models/$name.php";
    file_put_contents($file, <<<PHP
<?php

use SDF\Spark\Model;

/**
 * Model $name
 */
class $name extends Model
{
    // Override table name if needed:
    // protected static string \$table = '{$name}s';
}
PHP);
    echo "Model '$name' created at $file\n";
  }

  /**
   * Generate a migration stub using Spark ORM.
   *
   * @param string|null $name
   */
  private function generateMigration(?string $name): void
  {
    if (!$name) {
      echo "Migration name can't be empty.\n";
      $name = readline("Enter migration name: ");
    }

    @mkdir("app/migrations", 0755, true);
    $timestamp = date("YmdHis");
    $className = "{$name}_{$timestamp}";
    $file = "app/migrations/{$className}.php";

    file_put_contents($file, <<<PHP
<?php

/**
 * Migration: $name
 * Created: $timestamp
 */
class $className
{
    public function up(\PDO \$pdo): void
    {
        // Write migration SQL here
        // \$pdo->exec("CREATE TABLE ...");
    }

    public function down(\PDO \$pdo): void
    {
        // Write rollback SQL here
        // \$pdo->exec("DROP TABLE ...");
    }
}
PHP);
    echo "Migration '$className' created at $file\n";
  }

  /**
   * Generate a controller file.
   *
   * @param string|null $name
   */
  private function generateController(?string $name): void
  {
    if (!$name) {
      echo "Controller name can't be empty.\n";
      $name = readline("Enter controller name: ");
    }

    @mkdir(dirname("app/controllers/$name.php"), 0755, true);
    $file = "app/controllers/$name.php";
    file_put_contents($file, <<<PHP
<?php

use SDF\Controller;

/**
 * Controller $name
 */
class $name extends Controller
{
    public function index(): void
    {
        echo "Welcome to $name";
    }
}
PHP);
    echo "Controller '$name' created at $file\n";
  }

  /**
   * Append a new route to routes config.
   *
   * @param string|null $name
   */
  private function generateRoute(?string $name): void
  {
    if (!$name) {
      echo "Route name can't be empty.\n";
      $name = readline("Enter route name: ");
    }

    $controllerMethod = $this->argv[4] ?? "Controller/method";
    $requestType = $this->argv[5] ?? "GET";

    file_put_contents(
      "app/config/routes.php",
      "\n\$config['/$name'] = ['$controllerMethod', '$requestType'];",
      FILE_APPEND
    );
    echo "Route '/$name' appended to app/config/routes.php\n";
  }

  /**
   * Generate a helper file.
   *
   * @param string|null $name
   */
  private function generateHelper(?string $name): void
  {
    if (!$name) {
      echo "Helper name can't be empty.\n";
      $name = readline("Enter helper name: ");
    }

    @mkdir("app/helpers", 0755, true);
    $file = "app/helpers/$name.php";
    file_put_contents($file, "<?php\n\n// Helper: $name\n");
    echo "Helper '$name' created at $file\n";
  }

  /**
   * Generate a config file.
   *
   * @param string|null $name
   */
  private function generateConfig(?string $name): void
  {
    if (!$name) {
      echo "Config name can't be empty.\n";
      exit(1);
    }

    @mkdir("app/config", 0755, true);
    $file = "app/config/$name.php";
    file_put_contents($file, <<<PHP
<?php

/**
 * $name Configuration
 * Load using: load_config('$name');
 * @var array \$config
 */
if (!defined('SDF')) die('Security warning.');

\$config['$name'] = [
    'key' => 'value',
];
PHP);
    echo "Config '$name' created at $file\n";
  }

  /**
   * Generate a view file.
   *
   * @param string|null $name
   */
  private function generateView(?string $name): void
  {
    if (!$name) {
      echo "View name can't be empty.\n";
      exit(1);
    }

    @mkdir(dirname("app/views/$name.php"), 0755, true);
    $file = "app/views/$name.php";
    file_put_contents($file, "<h1>$name works!</h1>\n");
    echo "View '$name' created at $file\n";
  }

  // ─── Database ─────────────────────────────────────────────────────────────

  /**
   * Route to database sub-commands.
   */
  private function handleDatabase(): void
  {
    if (count($this->argv) < 3) {
      $this->printUsage();
      exit(1);
    }

    switch ($this->argv[2]) {
      case "migrate":
        $this->migrate();
        break;
      case "rollback":
        $this->rollback();
        break;
      case "seed":
        $this->seed();
        break;
      case "reset":
        $this->migrate();
        $this->seed();
        break;
      default:
        $this->printUsage();
        break;
    }
  }

  /**
   * Run all pending migrations using raw PDO.
   */
  private function migrate(): void
  {
    $pdo = $this->getPdo();
    echo "Running migrations...\n";
    foreach (glob("app/migrations/*.php") as $file) {
      echo "  → " . basename($file) . "\n";
      require_once $file;
      $className = pathinfo($file, PATHINFO_FILENAME);
      $migration = new $className();
      $migration->up($pdo);
    }
    echo "All migrations complete.\n";
  }

  /**
   * Rollback the last migration.
   */
  private function rollback(): void
  {
    $pdo = $this->getPdo();
    $files = glob("app/migrations/*.php");
    if (empty($files)) {
      echo "No migrations to rollback.\n";
      return;
    }
    $last = end($files);
    echo "Rolling back " . basename($last) . "...\n";
    require_once $last;
    $className = pathinfo($last, PATHINFO_FILENAME);
    $migration = new $className();
    $migration->down($pdo);
    echo "Rollback complete.\n";
  }

  /**
   * Run seed classes (stub for future implementation).
   */
  private function seed(): void
  {
    echo "Seeding... (implement Seeder classes in app/seeds/)\n";
  }

  /**
   * Build a PDO instance from environment/.env config.
   *
   * @return PDO
   */
  private function getPdo(): PDO
  {
    $host = $this->config['DATABASE_HOST'] ?? '127.0.0.1';
    $name = $this->config['DATABASE_NAME'] ?? '';
    $user = $this->config['DATABASE_USER'] ?? 'root';
    $pass = $this->config['DATABASE_PASSWORD'] ?? '';

    return new PDO("mysql:host=$host;dbname=$name;charset=utf8", $user, $pass, [
      PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION,
    ]);
  }

  // ─── Dev Server ───────────────────────────────────────────────────────────

  /**
   * Start PHP built-in dev server.
   */
  private function handleDevServer(): void
  {
    $port = in_array("-p", $this->argv)
      ? $this->argv[array_search("-p", $this->argv) + 1]
      : 8080;
    $quiet = in_array("-q", $this->argv);

    if (!$quiet) {
      $this->showBanner();
      echo "[INFO] Starting SDF development server on port $port...\n";
    }

    if ($this->isPortInUse($port)) {
      echo "[ERROR] Port $port already in use.\n";
      exit(1);
    }

    passthru("php -S localhost:$port index.php");

    if (!$quiet) {
      echo "[INFO] Development server stopped.\n";
    }
  }

  // ─── Utilities ────────────────────────────────────────────────────────────

  /** @param int $port @return bool */
  private function isPortInUse(int $port): bool
  {
    return !empty(shell_exec("lsof -i:$port"));
  }

  /** Print banner. */
  private function showBanner(): void
  {
    echo "------------------------------------------------------\n";
    echo "| SDF Framework v2.0.0  (c) devsimsek               |\n";
    echo "| Do not use devserver in production.                |\n";
    echo "------------------------------------------------------\n";
  }

  /** Print usage help. */
  private function printUsage(): void
  {
    echo "Usage: php sdf/cli [command] [subcommand] [options]\n\n";
    echo "Commands:\n";
    echo "  g|generate [type] [name]    Generate a new component\n";
    echo "    model|m [name]            Spark ORM model\n";
    echo "    migration|migrate [name]  Migration stub\n";
    echo "    controller|c [name]       Controller\n";
    echo "    route|r [name]            Append a route\n";
    echo "    helper|h [name]           Helper file\n";
    echo "    config|cfg [name]         Config file\n";
    echo "    view|v [name]             View file\n";
    echo "\n";
    echo "  db|database [action]        Database actions\n";
    echo "    migrate                   Run all migrations\n";
    echo "    rollback                  Rollback last migration\n";
    echo "    seed                      Seed the database\n";
    echo "    reset                     Migrate + seed\n";
    echo "\n";
    echo "  serve|devserver [-p port] [-q]   Start dev server (default port 8080)\n";
  }
}

$cli = new Cli($argv);
$cli->handle();
