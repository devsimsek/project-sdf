    }

    /**
     * Generate a middleware file.
     *
     * @param string|null $name
     */
    private function generateMiddleware(?string $name): void
    {
        if (!$name) {
            echo "Middleware name can't be empty.\n";
            exit(1);
        }

        @mkdir("app/middlewares", 0755, true);
        $file = "app/middlewares/$name.php";
        $template = <<<'PHP'
        <?php

        namespace App\Middlewares;

        use SDF\Middleware;
        use SDF\Request;

        /**
         * Middleware __NAME__
         */
        class __NAME__ implements Middleware
        {
            /**
             * Handle the incoming request.
             *
             * @param Request $request
             * @param \Closure $next
             * @return mixed
             */
            public function handle(Request $request, \Closure $next): mixed
            {
                // Logic before request...

                $response = $next($request);

                // Logic after request...

                return $response;
            }
        }
        PHP;
        file_put_contents($file, strtr($template, ["__NAME__" => $name]));
        echo "Middleware '$name' created at $file\n";
    }

