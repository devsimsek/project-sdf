# SDF Framework .gitignore

# ─── Dependencies ─────────────────────────────────────────────────────────────
/vendor/
composer.lock

# ─── IDE ──────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Runtime cache ────────────────────────────────────────────────────────────
sdf_routes.cache
sdf_config.cache
app/cache/
app/cache/*

# ─── Secrets / environment ────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
/logs/

# ─── Build output ─────────────────────────────────────────────────────────────
/dist/
/build/

# ─── Test artifacts (source tracked, outputs ignored) ─────────────────────────
/.phpunit.cache/
/.phpunit.result.cache
/coverage/

# PHP CS Fixer
/.php_cs.cache
/.php-cs-fixer.cache
.phpunit.cache
.phpunit.result.cache

# PHPStan cache
/phpstan.cache

# CLI generator temp folders
/tests/cli-temp/

# Misc temp
*.cache
*.tmp
.phpactor.json
